---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Mobile World Timaru" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Mobile phones, repairs, and accessories."
    />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/cropped-android-chrome-512x512-1-32x32.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/cropped-android-chrome-512x512-1-180x180.png"
    />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-page text-slate-900 antialiased">
    <slot />
  </body>
</html>
