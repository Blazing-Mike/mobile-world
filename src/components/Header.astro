<header
  class="mb-8 flex items-center container mx-auto justify-between gap-4 md:mb-10 px-4"
>
  <div class="flex items-center gap-3">
    <img src="/logo-dark.png" alt="Mobile World Timaru" class="h-10 w-auto" />
  </div>

  <nav
    class="hidden items-center gap-8 text-sm font-medium text-slate-700 md:flex"
  >
    <a class="nav-link" href="#">Home</a>
    <a class="nav-link" href="#">Services</a>
    <a class="nav-link" href="#">Reviews</a>
    <a class="nav-link" href="#">Our Location</a>
  </nav>

  <!-- Mobile hamburger -->
  <button
    id="menu-toggle"
    class="relative z-50 flex h-10 w-10 items-center justify-center rounded-lg transition hover:bg-slate-100 md:hidden"
    aria-label="Open menu"
  >
    <svg
      id="hamburger-icon"
      class="h-6 w-6 text-slate-800 transition-transform duration-300"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <line
        x1="4"
        y1="6"
        x2="20"
        y2="6"
        class="hamburger-line origin-center transition-all duration-300"></line>
      <line
        x1="4"
        y1="12"
        x2="20"
        y2="12"
        class="hamburger-line origin-center transition-all duration-300"></line>
      <line
        x1="4"
        y1="18"
        x2="20"
        y2="18"
        class="hamburger-line origin-center transition-all duration-300"></line>
    </svg>
  </button>

  <a href="tel:032646091" class="glass-btn group hidden md:flex">
    <span
      class="text-sm font-bold tracking-wide text-slate-800 transition-colors duration-300 group-hover:text-sky-600"
      >03 264 6091</span
    >
    <span
      class="text-[10px] font-semibold tracking-[0.12em] text-slate-500 uppercase transition-colors duration-300 group-hover:text-sky-500"
      >Free Quote</span
    >
  </a>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 flex translate-x-full flex-col bg-white/95 backdrop-blur-lg transition-transform duration-500 ease-in-out md:hidden"
>
  <nav
    class="mt-24 flex flex-col items-center gap-6 text-lg font-semibold text-slate-800"
  >
    <a href="#" class="mobile-nav-link transition-colors hover:text-sky-500"
      >Home</a
    >
    <a href="#" class="mobile-nav-link transition-colors hover:text-sky-500"
      >Services</a
    >
    <a href="#" class="mobile-nav-link transition-colors hover:text-sky-500"
      >Reviews</a
    >
    <a href="#" class="mobile-nav-link transition-colors hover:text-sky-500"
      >Our Location</a
    >
    <a
      href="tel:032646091"
      class="mt-4 inline-flex items-center gap-2 rounded-full bg-sky-500 px-7 py-3.5 text-sm font-bold tracking-wide text-white uppercase shadow-lg shadow-sky-500/25 transition hover:bg-sky-600"
    >
      Call 03 264 6091
    </a>
  </nav>
</div>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const lines = document.querySelectorAll<SVGLineElement>(".hamburger-line");
  let isOpen = false;

  toggle?.addEventListener("click", () => {
    isOpen = !isOpen;
    if (isOpen) {
      menu?.classList.remove("translate-x-full");
      menu?.classList.add("translate-x-0");
      // Animate to X
      if (lines[0]) {
        lines[0].setAttribute("transform", "rotate(45 12 12)");
        lines[0].setAttribute("y1", "12");
        lines[0].setAttribute("y2", "12");
      }
      if (lines[1]) {
        lines[1].style.opacity = "0";
      }
      if (lines[2]) {
        lines[2].setAttribute("transform", "rotate(-45 12 12)");
        lines[2].setAttribute("y1", "12");
        lines[2].setAttribute("y2", "12");
      }
      document.body.style.overflow = "hidden";
    } else {
      menu?.classList.remove("translate-x-0");
      menu?.classList.add("translate-x-full");
      // Animate back to hamburger
      if (lines[0]) {
        lines[0].removeAttribute("transform");
        lines[0].setAttribute("y1", "6");
        lines[0].setAttribute("y2", "6");
      }
      if (lines[1]) {
        lines[1].style.opacity = "1";
      }
      if (lines[2]) {
        lines[2].removeAttribute("transform");
        lines[2].setAttribute("y1", "18");
        lines[2].setAttribute("y2", "18");
      }
      document.body.style.overflow = "";
    }
  });

  // Close on link click
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      isOpen = false;
      menu?.classList.remove("translate-x-0");
      menu?.classList.add("translate-x-full");
      if (lines[0]) {
        lines[0].removeAttribute("transform");
        lines[0].setAttribute("y1", "6");
        lines[0].setAttribute("y2", "6");
      }
      if (lines[1]) {
        lines[1].style.opacity = "1";
      }
      if (lines[2]) {
        lines[2].removeAttribute("transform");
        lines[2].setAttribute("y1", "18");
        lines[2].setAttribute("y2", "18");
      }
      document.body.style.overflow = "";
    });
  });
</script>
