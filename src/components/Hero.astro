---
const base = import.meta.env.BASE_URL;
---

<section
  class="hero-shell overflow-hidden rounded-[28px] border border-white/60 shadow-xl shadow-slate-300/40"
>
  <div
    class="grid gap-8 px-6 py-8 md:grid-cols-2 md:gap-6 md:px-14 md:py-10 md:items-center"
  >
    <div class="z-10 flex max-w-2xl flex-col justify-center">
      <h1
        class="hero-animate text-balance text-4xl leading-tight font-extrabold tracking-[-0.02em] text-slate-950 md:text-6xl"
      >
        Your One-Stop Shop for Mobile Phones, Repairs, and Accessories in Timaru
      </h1>
      <p
        class="hero-animate mt-6 max-w-[48ch] text-base leading-relaxed text-slate-600 md:text-lg"
        style="animation-delay: 0.15s"
      >
        Discover top brands, expert repairs, and quality accessories, all under
        one roof. Get the best deals in town with fast turnaround and trusted
        local service.
      </p>
      <div
        class="hero-animate mt-8 flex flex-wrap items-center gap-4"
        style="animation-delay: 0.3s"
      >
        <a
          href="#"
          class="inline-flex items-center gap-3 rounded-full bg-sky-500 px-7 py-4 text-sm font-bold tracking-[0.06em] text-white uppercase shadow-lg shadow-sky-600/30 transition hover:-translate-y-0.5 hover:bg-sky-600"
        >
          Book A Repair
          <span aria-hidden="true" class="text-lg leading-none">↗</span>
        </a>
        <a
          href="#"
          class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white/60 px-6 py-4 text-sm font-semibold tracking-wide text-slate-700 transition hover:-translate-y-0.5 hover:border-sky-300 hover:text-sky-600 hover:shadow-md"
        >
          View Our Services
          <span aria-hidden="true" class="text-base leading-none">→</span>
        </a>
      </div>

      <!-- Trust badges -->
      <div
        class="hero-animate mt-8 flex items-center gap-3"
        style="animation-delay: 0.45s"
      >
        <div class="flex -space-x-1.5">
          <span
            class="flex h-8 w-8 items-center justify-center rounded-full bg-sky-100 text-xs font-bold text-sky-600 ring-2 ring-white"
            >J</span
          >
          <span
            class="flex h-8 w-8 items-center justify-center rounded-full bg-amber-100 text-xs font-bold text-amber-600 ring-2 ring-white"
            >S</span
          >
          <span
            class="flex h-8 w-8 items-center justify-center rounded-full bg-emerald-100 text-xs font-bold text-emerald-600 ring-2 ring-white"
            >M</span
          >
          <span
            class="flex h-8 w-8 items-center justify-center rounded-full bg-purple-100 text-xs font-bold text-purple-600 ring-2 ring-white"
            >A</span
          >
        </div>
        <div class="text-sm text-slate-500">
          <span class="text-amber-500">★★★★★</span>
          <span class="ml-1 font-semibold text-slate-700">200+</span> five-star reviews
        </div>
      </div>
    </div>

    <div
      class="relative flex min-h-85 items-center justify-center md:min-h-130"
    >
      <div
        class="absolute top-1/2 left-1/2 h-85 w-85 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#f2eacd] md:h-120 md:w-120"
      >
      </div>
      <img
        src={`${base}fix-phone-timaru-near-me.webp`}
        alt="Phone repair services in Timaru near me"
        class="hero-animate relative z-10 h-auto w-full max-w-120 object-contain drop-shadow-[0_26px_32px_rgba(15,23,42,0.15)]"
        style="animation-delay: 0.2s"
      />
    </div>
  </div>

  <div class="brand-carousel overflow-hidden bg-sky-500 py-5">
    <div class="brand-track">
      <span class="brand-item"
        ><svg viewBox="0 0 24 24" class="h-8 w-8 fill-current"
          ><path
            d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11"
          ></path></svg
        ></span
      >
      <span class="brand-item"
        ><img
          src={`${base}samsung-phone.png`}
          alt="Samsung"
          class="h-8 w-auto brightness-0 invert"
        /></span
      >
      <span class="brand-item"
        ><img
          src={`${base}huawei-phone.png`}
          alt="Huawei"
          class="h-8 w-auto brightness-0 invert"
        /></span
      >
      <span class="brand-item"
        ><img
          src={`${base}oppo-phone.png`}
          alt="Oppo"
          class="h-8 w-auto brightness-0 invert"
        /></span
      >
      <span class="brand-item"
        ><img
          src={`${base}vivo-phone.png`}
          alt="Vivo"
          class="h-8 w-auto brightness-0 invert"
        /></span
      >
      <!-- duplicate for seamless loop -->
      <span class="brand-item"
        ><svg viewBox="0 0 24 24" class="h-8 w-8 fill-current"
          ><path
            d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11"
          ></path></svg
        ></span
      >
      <span class="brand-item"
        ><img
          src={`${base}samsung-phone.png`}
          alt="Samsung"
          class="h-8 w-auto brightness-0 invert"
        /></span
      >
      <span class="brand-item"
        ><img
          src={`${base}huawei-phone.png`}
          alt="Huawei"
          class="h-8 w-auto brightness-0 invert"
        /></span
      >
      <span class="brand-item"
        ><img
          src={`${base}oppo-phone.png`}
          alt="Oppo"
          class="h-8 w-auto brightness-0 invert"
        /></span
      >
      <span class="brand-item"
        ><img
          src={`${base}vivo-phone.png`}
          alt="Vivo"
          class="h-8 w-auto brightness-0 invert"
        /></span
      >
    </div>
  </div>
</section>
